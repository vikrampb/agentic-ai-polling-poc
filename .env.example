# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Jira ───────────────────────────────────────────────────────────────────────
JIRA_HOST=mycompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=ATATT3...
JIRA_ISSUE_KEY=AQA-1

# ── Polling configuration ──────────────────────────────────────────────────────
# RUN_MODE: 'interactive' (default, same as original project)
#           'poll'        (auto-discover In Review stories, no prompt)
RUN_MODE=interactive

# Jira project key and status to poll for
JIRA_PROJECT_KEY=AQA
JIRA_READY_STATUS=In Review

# Poll interval in ms
# Demo:       120000  (2 minutes)
# Production: 3600000 (1 hour)
JIRA_POLL_INTERVAL_MS=120000

# Max stories to keep in the suite (0 = unlimited)
MAX_SUITE_SIZE=0

# Max run history entries to keep (11th run prunes the oldest)
MAX_HISTORY_RUNS=10

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=your-github-username
GITHUB_REPO=agentic-ai-polling-poc
GITHUB_BRANCH=agent/auto-tests

# ── SQLite ─────────────────────────────────────────────────────────────────────
DB_PATH=./data/users.db
